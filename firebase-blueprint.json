{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "displayName": { "type": "string", "description": "The display name of the user." },
        "email": { "type": "string", "format": "email", "description": "The email address of the user." },
        "photoURL": { "type": "string", "description": "The URL of the user's profile photo." },
        "role": { "type": "string", "enum": ["user", "admin", "analyst", "editor"], "description": "The role of the user." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Prediction": {
      "title": "Prediction History",
      "description": "Stores a user's prediction history.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user who made the prediction." },
        "matchId": { "type": "string", "description": "The ID of the match." },
        "homeTeam": { "type": "string", "description": "The name of the home team." },
        "awayTeam": { "type": "string", "description": "The name of the away team." },
        "homeLogo": { "type": "string", "description": "The logo URL of the home team." },
        "awayLogo": { "type": "string", "description": "The logo URL of the away team." },
        "correctScore": { "type": "string", "description": "The predicted correct score." },
        "confidence": { "type": "number", "description": "The confidence level of the prediction." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the prediction was made." }
      },
      "required": ["uid", "matchId", "homeTeam", "awayTeam", "homeLogo", "awayLogo", "correctScore", "confidence", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/prediction_history/{predictionId}": {
      "schema": "Prediction",
      "description": "User prediction history documents."
    }
  }
}
